# ── LLM ────────────────────────────────────────────────────────────────────
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-put-your-key-in-dot-env
MODEL_NAME=gpt-4o-mini
USE_MOCK_LLM=1
# Concurrent LLM calls per chunk-batch during statement normalization.
# Default 1 = fully sequential (safest for a low-tier per-minute token budget).
NORMALIZATION_MAX_PARALLEL_CHUNKS=1
# Per-chunk completion token ceiling for statement normalization. Default
# 4096 is tuned for Groq's on-demand tier; raise it (e.g. 8192) for a
# reasoning-style model, which spends a large share of its completion budget
# on hidden reasoning tokens before emitting the actual JSON.
NORMALIZATION_CHUNK_MAX_TOKENS=4096

# ── embeddings ───────────────────────────────────────────────────────────────
# Independent from the LLM settings above — the embedding provider isn't
# guaranteed to live at the same endpoint (e.g. chat pointed at a self-hosted
# vLLM instance that serves no embedding model). Reuses USE_MOCK_LLM as its
# mock-mode toggle (no separate USE_MOCK_EMBEDDINGS flag).
EMBEDDING_API_KEY=sk-put-your-embedding-key-in-dot-env
EMBEDDING_BASE_URL=https://api.openai.com/v1
# Output vector size. Must stay 768 unless the recommendations feature's
# ai_problem_statements.embedding column (Vector(768)) is migrated in lockstep.
EMBEDDING_DIMENSIONS=768
EMBEDDING_MODEL_NAME=text-embedding-3-small

# ── auth ───────────────────────────────────────────────────────────────────
# Shared secret with the Django backend. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AI_SERVICE_TOKEN=change-me

# ── own database (READ-WRITE, asyncpg) ─────────────────────────────────────
# A SEPARATE database owned by a dedicated least-privilege role — this service
# migrates & owns only these tables. It holds NO superuser creds and cannot
# reach the backend's appdb (provisioned by deploy/initdb/10-ai-roles.sh).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_appdb
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=change-me-ai-db-pass

# ── backend database (READ-ONLY) — optional; leave blank if no live backend ─
# Uses a dedicated read-only Postgres role (ai_readonly): SELECT-only on the
# backend's appdb, so the DB itself rejects any write.
BACKEND_DB_HOST=postgres
BACKEND_DB_PORT=5432
BACKEND_DB_NAME=appdb
BACKEND_DB_USER=ai_readonly
BACKEND_DB_PASSWORD=change-me-readonly-pass

# ── storage (S3-compatible object storage, e.g. SeaweedFS) ─────────────────
# Points at an already-running S3-compatible endpoint; the bucket must
# already exist there — this service never creates it. Required.
# In dev, these three buckets are created by the backend repo's own
# `ensure_storage_buckets` management command (services/storage_backends.py)
# — reuse its exact names rather than inventing new ones.
STORAGE_S3_BUCKET=pfm-statements-normalized
STORAGE_S3_ENDPOINT_URL=http://localhost:8333
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=dev-seaweed-key
STORAGE_S3_SECRET_KEY=dev-seaweed-secret
STORAGE_S3_USE_PATH_STYLE=true
# Dedicated bucket for statement OCR/extraction output (ingestion slice).
STORAGE_S3_OCR_BUCKET=pfm-statements-ocr

# ── mineru (document processing engine) ────────────────────────────────────
USE_MOCK_MINERU=1
MINERU_API_URL=mineru-server
MINERU_API_KEY=key

# ── observability (Langfuse LLM tracing) ────────────────────────────────────
# LANGFUSE_ENABLED is the on/off switch (default true — tracing is attempted
# on every startup). HOST/PUBLIC_KEY/SECRET_KEY below default to match the
# local self-hosted Langfuse stack's own headless-init values (compose/
# langfuse/docker-compose.yml — its own opt-in `observability` compose
# profile, off by default: `docker compose --profile observability up`, or
# `make dev-up-observability`), so enabling that profile is the only step
# needed to start seeing traces — no further .env editing required. If that
# profile isn't running, tracing attempts just fail open silently (FR-005) —
# no effect on requests either way.
#   - Set LANGFUSE_ENABLED=false to disable tracing outright — the three
#     values below are then not required (safe to leave blank).
#   - To use a cloud-hosted Langfuse instead, set LANGFUSE_HOST and the real
#     key pair from its UI — the local `observability` profile isn't needed.
#   - Blanking any of the three below while LANGFUSE_ENABLED stays true fails
#     startup immediately (app/core/config.py) rather than silently degrading
#     — it almost always means one was deleted/typo'd by mistake.
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=pk-lf-00000000-0000-0000-0000-000000000000
LANGFUSE_SECRET_KEY=sk-lf-00000000-0000-0000-0000-000000000000

# ── logging ──────────────────────────────────────────────────────────────
# One of DEBUG, INFO, WARNING, ERROR, CRITICAL — invalid values fail fast at startup.
LOG_LEVEL=INFO
# Off by default. When true, raw LLM prompt/completion and DB query content
# MAY be logged at DEBUG severity for local troubleshooting. MUST NEVER be
# enabled in production — logs a startup warning whenever it's true.
LOG_DEBUG_INCLUDE_RAW_CONTENT=false
