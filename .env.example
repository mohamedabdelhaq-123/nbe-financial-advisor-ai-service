# ── chat model ──────────────────────────────────────────────────────────────
AI_SERVICE_CHAT_MODEL__OPENAI_BASE_URL=https://api.openai.com/v1 # change me
AI_SERVICE_CHAT_MODEL__OPENAI_API_KEY=sk-put-your-key-in-dot-env  # change me
AI_SERVICE_CHAT_MODEL__MODEL_NAME=gpt-4o-mini # change me
AI_SERVICE_CHAT_MODEL__USE_MOCK=0
# Concurrent LLM calls per chunk-batch during statement normalization.
# Default 1 = fully sequential (safest for a low-tier per-minute token budget).
AI_SERVICE_CHAT_MODEL__NORMALIZATION_MAX_PARALLEL_CHUNKS=4
# Per-chunk completion token ceiling for statement normalization. Default
# 4096 is tuned for Groq's on-demand tier; raise it (e.g. 8192) for a
# reasoning-style model, which spends a large share of its completion budget
# on hidden reasoning tokens before emitting the actual JSON.
AI_SERVICE_CHAT_MODEL__NORMALIZATION_CHUNK_MAX_TOKENS=4096

# ── embeddings ───────────────────────────────────────────────────────────────
# Independent from the chat model settings above — the embedding provider isn't
# guaranteed to live at the same endpoint (e.g. chat pointed at a self-hosted
# vLLM instance that serves no embedding model). Reuses AI_SERVICE_CHAT_MODEL__USE_MOCK
# as its mock-mode toggle (no separate AI_SERVICE_EMBEDDINGS__USE_MOCK flag).
AI_SERVICE_EMBEDDINGS__API_KEY=sk-put-your-embedding-key-in-dot-env  # change me
AI_SERVICE_EMBEDDINGS__BASE_URL=https://api.openai.com/v1	# change me
# Output vector size. Must stay 768 unless the recommendations feature's
# ai_problem_statements.embedding column (Vector(768)) is migrated in lockstep.
AI_SERVICE_EMBEDDINGS__DIMENSIONS=768
AI_SERVICE_EMBEDDINGS__MODEL_NAME=text-embedding-3-small # change me

# ── auth ───────────────────────────────────────────────────────────────────
# Shared secret with the Django backend. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Not AI_SERVICE_TOKEN__* — this is the flat `token` field on Settings, and
# `AI_SERVICE_` here is the env_prefix every other var below also carries.
AI_SERVICE_TOKEN=change-me

# ── own database (READ-WRITE, asyncpg) ─────────────────────────────────────
# A SEPARATE database owned by a dedicated least-privilege role — this service
# migrates & owns only these tables. It holds NO superuser creds and cannot
# reach the backend's appdb (provisioned by deploy/initdb/10-ai-roles.sh).
AI_SERVICE_OWN_DB__POSTGRES_HOST=postgres
AI_SERVICE_OWN_DB__POSTGRES_PORT=5432
AI_SERVICE_OWN_DB__POSTGRES_DB=ai_appdb
AI_SERVICE_OWN_DB__POSTGRES_USER=ai_user
AI_SERVICE_OWN_DB__POSTGRES_PASSWORD=change-me-ai-db-pass

# ── backend database (READ-ONLY) — required in every real deployment ───────
# Uses a dedicated read-only Postgres role (ai_readonly): SELECT-only on the
# backend's appdb, so the DB itself rejects any write.
AI_SERVICE_BACKEND_DB__HOST=postgres
AI_SERVICE_BACKEND_DB__PORT=5432
AI_SERVICE_BACKEND_DB__NAME=appdb
AI_SERVICE_BACKEND_DB__USER=ai_readonly
AI_SERVICE_BACKEND_DB__PASSWORD=change-me-readonly-pass

# ── storage (S3-compatible object storage, e.g. SeaweedFS) ─────────────────
# Points at an already-running S3-compatible endpoint; the bucket must
# already exist there — this service never creates it. Required.
# In dev, these three buckets are created by the backend repo's own
# `ensure_storage_buckets` management command (services/storage_backends.py)
# — reuse its exact names rather than inventing new ones. The endpoint uses
# the container's service name, not localhost — this repo's dev compose
# joins the network the backend repo's own dev stack creates (postgres +
# seaweedfs), so "seaweedfs" resolves there, same as the real deploy compose.
AI_SERVICE_STORAGE__S3_BUCKET=pfm-statements-normalized
AI_SERVICE_STORAGE__S3_ENDPOINT_URL=http://seaweedfs:8333
AI_SERVICE_STORAGE__S3_REGION=us-east-1
AI_SERVICE_STORAGE__S3_ACCESS_KEY=dev-seaweed-key
AI_SERVICE_STORAGE__S3_SECRET_KEY=dev-seaweed-secret
AI_SERVICE_STORAGE__S3_USE_PATH_STYLE=true
# Dedicated bucket for statement OCR/extraction output (ingestion slice).
AI_SERVICE_STORAGE__S3_OCR_BUCKET=pfm-statements-ocr

# ── mineru (document processing engine) ────────────────────────────────────
AI_SERVICE_MINERU__USE_MOCK=0
AI_SERVICE_MINERU__API_URL=mineru-server  # change me
AI_SERVICE_MINERU__API_KEY=key  # change me

# ── observability (Langfuse LLM tracing) ────────────────────────────────────
# Defaults match the local self-hosted stack (make dev-up-observability) —
# ENABLED=false disables tracing outright (HOST/PUBLIC_KEY/SECRET_KEY then
# unneeded); for a cloud-hosted Langfuse instead, set HOST + the real key
# pair from its UI. Required (non-empty) whenever ENABLED=true.
AI_SERVICE_LANGFUSE__ENABLED=false
AI_SERVICE_LANGFUSE__HOST=http://langfuse-web:3000
AI_SERVICE_LANGFUSE__PUBLIC_KEY=pk-lf-00000000-0000-0000-0000-000000000000
AI_SERVICE_LANGFUSE__SECRET_KEY=sk-lf-00000000-0000-0000-0000-000000000000

# ── logging ──────────────────────────────────────────────────────────────
# One of DEBUG, INFO, WARNING, ERROR, CRITICAL — invalid values fail fast at startup.
AI_SERVICE_LOGGING__LEVEL=INFO
AI_SERVICE_LOGGING__DEBUG_INCLUDE_RAW_CONTENT=false
